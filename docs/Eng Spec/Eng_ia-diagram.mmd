flowchart LR
    %% Reptile Love+ IA - Designer Review Version

    subgraph NAV["Fixed Bottom Navigation / Global Shell"]
        direction TB
        NavShell["Phone Mock Shell<br/>TopBar / Content<br/>FAB / BottomNav"]
        TabPet["Reptiles"]
        TabDiscuss["Discussion"]
        TabHome["Home"]
        TabStore["Shop"]
        TabMember["Member"]
    end

    subgraph HOME["Home: Entry Overview"]
        direction TB
        HomeMain["Home Main Screen<br/>Long Scrollable Page"]
        HomeTasks["Today Widget<br/>Today Tasks<br/>7-Day Upcoming"]
        HomeAI["Pet AI+ Assistant<br/>Returns to Home"]
        HomeQuick["Shortcut Entries<br/>My Reptiles / Records<br/>Plan / Album"]
        HomeCalendar["Calendar Block<br/>Red: Feeding<br/>Blue: Other"]
        HomeContent["Content Preview<br/>Articles / Products"]
        Construction["Construction Screen<br/>Mock Placeholder"]
    end

    subgraph PET["Reptiles Core"]
        direction TB
        PetHub["Reptiles Hub<br/>Core Feature Entries"]
        PetList["My Reptiles List<br/>Cards Open Profile"]
        AddPet["Add Reptile<br/>Save to List"]
        PetProfile["Pet Profile<br/>Data / Charts<br/>Timeline / Photos"]
        EditPet["Edit Reptile<br/>Save to Profile"]
        Record["Feeding / Records<br/>Species Template<br/>Custom Tags"]
        Plan["Feeding Plan<br/>List / Settings<br/>Create / Edit"]
        Album["Reptile Album<br/>All / Selected Filter"]
        History["History Records<br/>Abnormal / Photo Badges"]
        AIChat["Pet AI+ Chat<br/>Switch Reptile<br/>Mock Input"]
    end

    subgraph SUPPORT["Support Tools: Calendar / Photo / AI"]
        direction TB
        Calendar["Calendar Page<br/>Full Monthly Calendar"]
        CalendarFilter["Filters<br/>Reptile / Event Type"]
        EventList["Selected-Date Event List"]
        EventDetail["Event Details<br/>Go to Profile / Records"]
        PhotoDetail["Photo Preview<br/>Reassign to Reptile"]
    end

    subgraph DISCUSS["Discussion"]
        direction TB
        DiscussList["Discussion List<br/>Cards / Likes / Replies"]
        Article["Article Detail<br/>Content / Images<br/>Comments"]
        Editor["Post Editor<br/>Add / Edit Shared"]
        Comment["Comments<br/>Validate / Pin New"]
    end

    subgraph STORE["Shop"]
        direction TB
        Shop["Shop List<br/>Product Cards<br/>Add to Cart"]
        Product["Product Detail<br/>Specs / Stock<br/>Shipping"]
        Cart["Cart<br/>Quantity / Total"]
        Checkout["Checkout<br/>Recipient / Notes<br/>Mock Submit"]
    end

    subgraph MEMBER["Member"]
        direction TB
        MemberGate["Member Page<br/>Logged-Out Guide<br/>Logged-In Tabs"]
        Login["Login / Register<br/>Email / Password<br/>OAuth Mock"]
        MemberProfile["My Profile<br/>Name / Email"]
        MemberPets["My Reptiles Summary"]
        MemberPosts["My Articles"]
        MemberOrders["My Orders<br/>Mock Order Switch"]
        MemberNotify["Notification Settings<br/>Single Toggle<br/>Apple Settings Mock"]
    end

