flowchart LR
    %% 爬蟲寵愛+ IA - Designer Review Version

    subgraph NAV["固定底部導覽 / Global Shell"]
        direction TB
        NavShell["手機 Mock Shell\nTopBar / 可滾動內容 / FAB / BottomNav"]
        TabPet["爬寵"]
        TabDiscuss["討論"]
        TabHome["首頁"]
        TabStore["商店"]
        TabMember["會員"]
    end

    subgraph HOME["首頁 Home：入口總覽"]
        direction TB
        HomeMain["首頁主畫面\n長頁，可下滑"]
        HomeTasks["Today Widget\n今日任務 / 7 天待辦"]
        HomeAI["寵 AI+ 入口\n返回首頁脈絡"]
        HomeQuick["快捷入口\n爬寵 / 紀錄 / 計畫 / 相簿"]
        HomeCalendar["月曆 Block\n紅點餵食 / 藍點其他"]
        HomeContent["內容預覽\n討論文章 / 商品"]
        Construction["施工中頁\nmock placeholder"]
    end

    subgraph PET["爬寵核心 Pet Core"]
        direction TB
        PetHub["爬寵 Hub\n四大核心入口"]
        PetList["我的爬寵列表\n卡片進個體頁"]
        AddPet["新增寵物\n儲存後回列表"]
        PetProfile["寵物個體頁\n資料 / 圖表 / 時間軸 / 照片"]
        EditPet["編輯寵物\n儲存後回個體頁"]
        Record["餵食／紀錄\n物種模板 / 自定義標籤"]
        Plan["餵食計畫\nlist / settings / create / edit"]
        Album["爬寵相簿\n全部或指定寵物 filter"]
        History["歷史紀錄\n異常 / 有照片 badge"]
        AIChat["寵 AI+ 對話\n切換寵物 / mock input"]
    end

    subgraph SUPPORT["支援工具 Calendar / Photo / AI"]
        direction TB
        Calendar["日曆頁\n整月月曆"]
        CalendarFilter["篩選\n寵物 / 事件類型"]
        EventList["當日事件列表"]
        EventDetail["事件詳情\n前往寵物頁 / 紀錄頁"]
        PhotoDetail["照片放大檢視\n重新標記歸屬寵物"]
    end

    subgraph DISCUSS["討論 Community"]
        direction TB
        DiscussList["討論列表\n文章卡 / 愛心 / 回覆數"]
        Article["文章詳情\n內容 / 圖片 / 留言"]
        Editor["發文編輯器\n新增與編輯共用"]
        Comment["留言互動\n空白驗證 / 成功後置頂"]
    end

    subgraph STORE["商店 Commerce"]
        direction TB
        Shop["商店列表\n商品卡 / 加入購物車"]
        Product["商品詳情\n規格 / 庫存 / 運送"]
        Cart["購物車\n數量累加 / 總計"]
        Checkout["結帳\n收件資料 / 備註 / mock 送出"]
    end

    subgraph MEMBER["會員 Member"]
        direction TB
        MemberGate["會員頁\n未登入引導 / 已登入分頁"]
        Login["登入／註冊\nEmail / 密碼 / 暱稱 / OAuth mock"]
        MemberProfile["會員資料\n名稱 / Email"]
        MemberPets["我的爬寵摘要"]
        MemberPosts["我的文章"]
        MemberOrders["我的訂單\nmock 訂單切換"]
        MemberNotify["通知設定\n單一開關 / Apple 設定 mock"]
    end

    NavShell --> TabPet
